DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-vm-ip,your-domain
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
CORS_ALLOWED_ORIGINS=http://your-vm-ip,http://your-domain
CSRF_TRUSTED_ORIGINS=http://your-vm-ip,http://your-domain

DB_NAME=chatsense_db
DB_USER=postgres
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

GEMINI_API_KEY=replace-with-gemini-key
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token

# Optional: enable the threaded sync loop only for local runserver use.
ENABLE_RUNSERVER_STOCK_SYNC=False
